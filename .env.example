# ============================================================
# CityWalk Agent 环境变量配置模板
# ============================================================
# 使用方法：
# 1. 复制此文件为 .env
# 2. 将下面的占位符替换为你的真实 API Key
# cp .env.example .env
# ============================================================

# ============================================================
# 高德地图 API 配置 (必填)
# 申请地址: https://lbs.amap.com/
# ============================================================
AMAP_KEY=your_amap_key_here
AMAP_JS_KEY=your_amap_js_key_here
AMAP_JS_SECURITY_CODE=your_amap_js_security_code_here

# ============================================================
# LLM API 配置 (必填)
# 支持 OpenAI、DeepSeek、MiniMax 等兼容 OpenAI API 的提供商
# ============================================================
LLM_KEY=your_llm_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_API_BASE=https://api.openai.com/v1

# ============================================================
# CityWalk 模型路由配置 (可选)
# 默认使用 deepseek-v3.2 和 MiniMax-M2.5
# ============================================================
CITYWALK_INTENT_MODEL=deepseek-v3.2
CITYWALK_PLANNER_MODEL=MiniMax-M2.5

# 可选：自定义 base URL
# CITYWALK_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# CITYWALK_PLANNER_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# CITYWALK_INTENT_PARSER_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 可选：各阶段模型覆盖
# CITYWALK_INTENT_PARSER_MODEL=MiniMax-M2.5
# CITYWALK_PLANNING_KNOWLEDGE_MODEL=MiniMax-M2.5
# CITYWALK_CORRIDOR_SELECTION_MODEL=MiniMax-M2.5
# CITYWALK_STOP_SELECTION_MODEL=MiniMax-M2.5
# CITYWALK_STOP_STAY_PLANNING_MODEL=MiniMax-M2.5
# CITYWALK_ROUTE_EXPERIENCE_MODEL=MiniMax-M2.5
# CITYWALK_ROUTE_SELECTION_MODEL=MiniMax-M2.5
# CITYWALK_FINAL_OUTPUT_REPAIR_MODEL=MiniMax-M2.5

# 可选：各阶段 base URL 覆盖
# CITYWALK_PLANNING_KNOWLEDGE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# CITYWALK_CORRIDOR_SELECTION_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# CITYWALK_STOP_SELECTION_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# CITYWALK_STOP_STAY_PLANNING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# CITYWALK_ROUTE_EXPERIENCE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# CITYWALK_ROUTE_SELECTION_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# CITYWALK_FINAL_OUTPUT_REPAIR_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ============================================================
# RAG 检索配置 (可选，但推荐配置以获得更好的路线规划效果)
# ============================================================

# Rerank 模型配置 (用于检索结果重排)
RAG_RERANK_MODEL=BAAI/bge-reranker-v2-m3
RAG_RERANK_BASE_URL=https://api.siliconflow.cn/v1/rerank
RAG_RERANK_API_KEY=your_rerank_api_key_here

# Embedding 模型配置 (用于向量检索)
RAG_EMBEDDING_API_KEY=your_embedding_api_key_here
RAG_EMBEDDING_BASE_URL=https://api.openai.com/v1

# Note Filter 模型配置 (用于过滤不相关的笔记)
RAG_NOTE_FILTER_BASE_URL=https://api.openai.com/v1
RAG_NOTE_FILTER_MODEL=google/gemini-3.1-flash-lite-preview
RAG_NOTE_FILTER_API_KEY=your_note_filter_api_key_here
